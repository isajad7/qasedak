DJANGO_SETTINGS_MODULE=core.settings.production
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1
DJANGO_DEBUG=False
SQLITE_DATABASE_PATH=/var/www/vpn_store/data/db.sqlite3
SMSFORWARDER_WEBHOOK_TOKEN=
PAYMENT_SMS_TIME_ZONE=Asia/Tehran

# Telegram bot tokens are stored in BotConfiguration records.
TELEGRAM_BOT_USERNAME=
# Configure Telegram API access through this HTTP proxy. Leave all values blank to disable.
TELEGRAM_PROXY_PROTOCOL=http
TELEGRAM_PROXY_HOST=
TELEGRAM_PROXY_PORT=
TELEGRAM_PROXY_USERNAME=
TELEGRAM_PROXY_PASSWORD=

# Legacy full proxy URL fallback. Prefer the structured TELEGRAM_PROXY_* variables above.
TELEGRAM_PROXY_URL=

# Keep this disabled when Telegram uses long polling.
TELEGRAM_WEBHOOK_RESPONSE_ENABLED=False

BOT_API_CONNECT_TIMEOUT_SECONDS=3
BOT_API_READ_TIMEOUT_SECONDS=8
XUI_PANEL_PROXY_URL=
