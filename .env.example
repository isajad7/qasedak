# Django core
DJANGO_SETTINGS_MODULE=core.settings.production
DJANGO_SECRET_KEY=generate-with-installer
DJANGO_DEBUG=False

# Hosts / CSRF / security
DJANGO_ALLOWED_HOSTS=example.com,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com
DJANGO_USE_X_FORWARDED_HOST=True

# Database
SQLITE_DATABASE_PATH=/opt/vpn-store/data/db.sqlite3

# Locale
DJANGO_LANGUAGE_CODE=fa
DJANGO_TIME_ZONE=Asia/Tehran

# Telegram bot
# Bot tokens are stored in BotConfiguration database records, not in .env.
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_RESPONSE_ENABLED=False
BOT_API_CONNECT_TIMEOUT_SECONDS=3
BOT_API_READ_TIMEOUT_SECONDS=8

# Telegram proxy
# Leave all values blank to disable. Prefer structured fields over TELEGRAM_PROXY_URL.
TELEGRAM_PROXY_URL=
TELEGRAM_PROXY_PROTOCOL=http
TELEGRAM_PROXY_HOST=
TELEGRAM_PROXY_PORT=
TELEGRAM_PROXY_USERNAME=
TELEGRAM_PROXY_PASSWORD=

# X-UI / panel proxy
# Panel URL, username, and password are database-backed Panel fields.
XUI_PANEL_PROXY_URL=

# Payments / SMS
# Payment card settings are database-backed Store fields.
SMSFORWARDER_WEBHOOK_TOKEN=
PAYMENT_SMS_TIME_ZONE=Asia/Tehran

# Upload limits
PAYMENT_RECEIPT_MAX_UPLOAD_SIZE=5242880

# Revenue Engine install defaults
# These are installer/bootstrap defaults for fresh installs. Current runtime config is DB-backed.
INSTALL_REVENUE_ENGINE_ENABLED=true
INSTALL_REVENUE_ENGINE_DRY_RUN=true

# Optional live checks
# Future installer/doctor runs should keep live external checks disabled unless explicitly requested.
INSTALL_RUN_LIVE_BOT_CHECK=false
INSTALL_RUN_LIVE_XUI_CHECK=false
INSTALL_SEND_TELEGRAM_TEST_MESSAGE=false

# Advanced SSL/security
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
